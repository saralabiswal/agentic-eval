# agentic-eval — Environment Configuration
# Copy to .env and fill in values.
# Default config runs with no API key required.

# ── Judge LLM (evaluates agent outputs) ────────────────────────────────────
# mock   → deterministic scripted scores (default, no key needed)
# ollama → local Ollama model (free, no account, requires docker-compose up)
# api    → OpenAI via LiteLLM (best quality, requires API key below)
EVAL_JUDGE_BACKEND=mock
EVAL_JUDGE_MODEL=gpt-4o

# ── System Under Test (SUT) LLM ────────────────────────────────────────────
# mock   → pre-scripted realistic agent outputs (default)
# ollama → real local inference via Ollama
# api    → real cloud LLM inference
# platform → banking-agentic-ai-platform pipeline API
SUT_BACKEND=mock
SUT_MODEL=llama3.2

# ── Ollama (only needed if either backend = ollama) ─────────────────────────
# Run: docker-compose up -d ollama
# Then: docker exec -it agentic-eval-ollama ollama pull llama3.2
# Recommended no-key pairing:
#   EVAL_JUDGE_BACKEND=ollama
#   EVAL_JUDGE_MODEL=qwen2.5:7b
#   SUT_BACKEND=ollama
#   SUT_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── API Key (only if EVAL_JUDGE_BACKEND=api or SUT_BACKEND=api) ────────────
# OPENAI_API_KEY=sk-...

# ── Banking Platform Integration (optional) ────────────────────────────────
# Set to true only when banking-agentic-ai-platform is running locally.
# Recommended real pipeline pairing:
#   BANKING_PLATFORM_ENABLED=true
#   BANKING_PLATFORM_URL=http://localhost:8000
#   EVAL_JUDGE_BACKEND=ollama
#   EVAL_JUDGE_MODEL=qwen2.5:7b
#   SUT_BACKEND=platform
#   SUT_MODEL=banking-platform
BANKING_PLATFORM_ENABLED=false
BANKING_PLATFORM_URL=http://localhost:8000

# ── Evaluation Defaults ─────────────────────────────────────────────────────
CONSISTENCY_RUNS=5
FAITHFULNESS_THRESHOLD=0.85
ANSWER_RELEVANCE_THRESHOLD=0.80
CONTEXT_PRECISION_THRESHOLD=0.70
CONSISTENCY_THRESHOLD=0.90

# ── API Server ──────────────────────────────────────────────────────────────
# Note: port 8001 to avoid conflict with banking platform (8000)
API_HOST=0.0.0.0
API_PORT=8001
LOG_LEVEL=INFO
